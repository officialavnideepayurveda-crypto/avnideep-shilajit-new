/*.webp
  Cache-Control: public, immutable, max-age=2592000
/*.jpg
  Cache-Control: public, immutable, max-age=2592000
/*.png
  Cache-Control: public, immutable, max-age=2592000
/manifest.webmanifest
  Cache-Control: public, max-age=604800
/*.html
  Cache-Control: public, max-age=3600, must-revalidate
/
  Cache-Control: public, max-age=3600, must-revalidate
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
