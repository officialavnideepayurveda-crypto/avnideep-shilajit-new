# Cloudflare Pages Headers - PRODUCTION OPTIMIZED for 1000+ concurrent users

# Global security & performance headers
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), browsing-topics=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-DNS-Prefetch-Control: on
  X-XSS-Protection: 1; mode=block
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin

# HTML pages - edge cache 10 min, browser revalidate every visit
# (Cloudflare serves from edge instantly, refreshes in background)
/
  Cache-Control: public, max-age=0, s-maxage=600, stale-while-revalidate=86400
  Content-Type: text/html; charset=utf-8
  Link: </AvnideepShilajit-main/images/mainimagee.webp>; rel=preload; as=image; fetchpriority=high
  Vary: Accept-Encoding

/index.html
  Cache-Control: public, max-age=0, s-maxage=600, stale-while-revalidate=86400

# Images - 1 year immutable cache (saves bandwidth!)
/AvnideepShilajit-main/images/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
  Access-Control-Allow-Origin: *
  Timing-Allow-Origin: *

/images/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts - 1 year immutable
*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Service worker - never cache (so SW updates ship)
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# PWA Manifest - 1 day
/manifest.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

# SEO files - 1 day
/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# Legal pages - 1 day cache
/privacy-policy.html
  Cache-Control: public, max-age=86400

/refund-policy.html
  Cache-Control: public, max-age=86400

/terms-and-conditions.html
  Cache-Control: public, max-age=86400

# API endpoint - NEVER cache + CORS for Razorpay/Pixel
/api/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: POST, OPTIONS, GET
  Access-Control-Allow-Headers: Content-Type
  Access-Control-Max-Age: 86400
